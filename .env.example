# Deployment env for MiroFish + our stock_seed orchestrator.
# Copy to `.env` (gitignored) and fill in the real keys.

# ===== LLM (MiroFish) — Gemini via its OpenAI-compatible endpoint =====
# Uses the project's GEMINI_API_KEY. gemini-2.5-flash (2.0-flash is retired).
LLM_API_KEY=your_gemini_api_key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash

# Optional "boost" LLM (leave the three unset entirely if not used).
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=

# ===== Zep memory graph (REQUIRED by MiroFish — it won't boot without it) =====
# Free monthly quota is fine for light use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key

# Cap the OASIS simulation length (rounds). The LLM plans a world duration that
# can be 100+ rounds; our patched runner truncates to this. Keep it modest —
# sims are LLM-heavy (README warns < 40).
OASIS_DEFAULT_MAX_ROUNDS=40

# ===== stock_seed orchestrator =====
# Shared read-only Postgres (stock prices + news). Server-side only — the host
# is internal infra and must never surface in any client response.
DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
# In compose this is overridden to http://mirofish:5001.
MIROFISH_BASE_URL=http://localhost:5001
DEFAULT_HORIZON_DAYS=5
NEWS_LIMIT=25
PRICE_WINDOW_DAYS=120
